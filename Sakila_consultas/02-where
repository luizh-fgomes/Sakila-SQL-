--Usando o WHERE

SELECT actor_id,first_name,last_name FROM actor
WHERE actor_id >=10;

SELECT customer_id,amount,amount - (amount * 0.10) 
FROM payment 
WHERE customer_id = 1;

SELECT * FROM payment;

SELECT payment_id,rental_id,amount FROM payment
WHERE amount BETWEEN 1.99 AND 3.99
ORDER BY payment_id ASC;

SELECT * FROM address
WHERE district = 'TEXAS' OR district ='California';

SELECT staff_id,amount,customer_id FROM payment
WHERE staff_id = 1 or amount = 0.99 AND customer_id <10;

SELECT * FROM payment
WHERE NOT staff_id = 1 AND NOT amount = 0.99;

--OU (!=)

SELECT * FROM payment
WHERE NOT staff_id = 1 AND amount != 0.99;
